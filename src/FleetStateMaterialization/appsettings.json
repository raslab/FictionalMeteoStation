{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "fleet-state-materialization",
    "ConsumersPerTopic": 24,
    "TelemetryTopic": "rover.telemetry.clean",
    "AlertsTopic": "rover.alerts"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "KeyTtlSeconds": 300
  },
  "AllowedHosts": "*"
}
